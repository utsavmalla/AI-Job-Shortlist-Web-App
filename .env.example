# Local Ollama (recommended for private, offline extraction).
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Ollama Cloud alternative for hosted deployments.
# Keep this server-only and set it as a deployment secret.
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_MODEL=gpt-oss:20b
# OLLAMA_API_KEY=your_ollama_api_key

# To use Gemini instead, set AI_PROVIDER=gemini and add an API key.
# Never prefix this with NEXT_PUBLIC_.
GEMINI_API_KEY=your_gemini_api_key
# Optional. Keep this pinned to a stable free-tier model.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional backend-only debug metadata for outbound requests.
# Does not log prompts, CV text, job text, API keys, or provider response bodies.
# EXTERNAL_REQUEST_DEBUG=true

# Optional local-only raw prompt logging for model requests.
# Logs pasted/fetched job text and CV text inside prompts. Do not enable in shared or production environments.
# EXTERNAL_REQUEST_PROMPT_DEBUG=true
