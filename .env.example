# Local Ollama (recommended for private, offline extraction).
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# To use Gemini instead, set AI_PROVIDER=gemini and add an API key.
# Never prefix this with NEXT_PUBLIC_.
GEMINI_API_KEY=your_gemini_api_key
# Optional. Keep this pinned to a stable free-tier model.
GEMINI_MODEL=gemini-2.5-flash-lite
